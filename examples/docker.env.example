# Copy to a local runtime env file and pass with: docker run --env-file /path/to/runtime.env ...

# Required model credentials: provide the pair that matches your Hermes provider selection.
# OpenAI-compatible endpoints can use either Hermes-native names or OPEN_AI_* compatibility names.
# If the endpoint runs on the Docker host, localhost is rewritten to host.docker.internal in the container.
# OPENAI_BASE_URL=http://host.docker.internal:8100/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=cx/gpt-5.4
# OPEN_AI_URL=http://localhost:8100/v1
# OPEN_AI_API_KEY=
# OPEN_AI_MODEL=cx/gpt-5.4
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# AI_GATEWAY_API_KEY=
# HF_TOKEN=

# Optional provider routing.
# HERMES_INFERENCE_PROVIDER=openrouter

# A2A runtime defaults.
A2A_ENABLED=true
A2A_HOST=0.0.0.0
A2A_PORT=8081
A2A_AGENT_NAME=hermes-a2a
A2A_AGENT_DESCRIPTION=Containerized Hermes agent with A2A enabled
A2A_AUTH_TOKEN=change-me

# Optional Hermes API server on :8642. For network bind, set API_SERVER_KEY too.
# API_SERVER_ENABLED=true
# API_SERVER_HOST=0.0.0.0
# API_SERVER_PORT=8642
# API_SERVER_KEY=change-me-api-server

# Internal wake-up route. Override if you want a custom secret.
A2A_WEBHOOK_SECRET=change-me-too
WEBHOOK_ENABLED=true
WEBHOOK_PORT=8644
